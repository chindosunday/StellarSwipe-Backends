{
  "title": "StellarSwipe — System Health",
  "uid": "stellarswipe-health",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (RPM)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 6 },
      "targets": [{
        "expr": "rate(http_requests_total{app='stellarswipe'}[1m]) * 60",
        "legendFormat": "{{method}} {{route}}"
      }]
    },
    {
      "id": 2,
      "title": "Response Time (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 6 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 6 },
      "targets": [{
        "expr": "rate(http_requests_errors_total[5m]) / rate(http_requests_total[5m]) * 100",
        "legendFormat": "Error %"
      }]
    },
    {
      "id": 4,
      "title": "Node.js Heap Usage",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 6, "w": 6, "h": 4 },
      "targets": [{
        "expr": "nodejs_heap_size_used_bytes / nodejs_heap_size_total_bytes * 100",
        "legendFormat": "Heap %"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] } }
    },
    {
      "id": 5,
      "title": "Active DB Connections",
      "type": "stat",
      "gridPos": { "x": 6, "y": 6, "w": 6, "h": 4 },
      "targets": [{ "expr": "postgresql_connections_active", "legendFormat": "Connections" }]
    },
    {
      "id": 6,
      "title": "Cache Hit Rate (%)",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 6, "w": 6, "h": 4 },
      "targets": [{
        "expr": "rate(cache_hits_total[5m]) / (rate(cache_hits_total[5m]) + rate(cache_misses_total[5m])) * 100",
        "legendFormat": "Hit Rate"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 50 }, { "color": "green", "value": 80 }] } }
    },
    {
      "id": 7,
      "title": "DB Query Time (p95)",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 6, "w": 6, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(db_query_duration_seconds_bucket[5m]))",
        "legendFormat": "{{operation}} {{entity}}"
      }]
    }
  ]
}
